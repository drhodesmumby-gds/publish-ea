      <!-- Foundational Technology -->
      <child xsi:type="archimate:DiagramObject" id="v-ft-azure" archimateElement="ft-azure">
        <bounds x="1120" y="0" width="150" height="55"/>      </child>
      <child xsi:type="archimate:DiagramObject" id="v-ft-entra" archimateElement="ft-entra">
