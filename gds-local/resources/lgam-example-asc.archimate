      <child xsi:type="archimate:DiagramObject" id="v-bp-assess" archimateElement="bp-assess">
        <bounds x="680" y="0" width="150" height="55"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="v-bp-plan" archimateElement="bp-plan">
        <bounds x="680" y="80" width="150" height="55"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="v-bp-safe" archimateElement="bp-safe">
        <bounds x="680" y="160" width="150" height="55"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="v-bp-provider" archimateElement="bp-provider">
