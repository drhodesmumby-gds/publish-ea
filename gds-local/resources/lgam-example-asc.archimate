      <!-- Integration -->
      <child xsi:type="archimate:DiagramObject" id="v-int-nhs" archimateElement="int-nhs">
        <bounds x="900" y="0" width="160" height="55"/>      </child>
      <child xsi:type="archimate:DiagramObject" id="v-int-dwp" archimateElement="int-dwp">
